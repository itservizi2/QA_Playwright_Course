    {
      "name": "Goals Collection",
      "item": [
        {
          "name": "Create Flow",
          "item": [
            {
              "name": "Create Goal Success",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test(\"Status code is 200\", function () {\r",
                      "    pm.response.to.have.status(201);\r",
                      "});\r",
                      "\r",
                      "const responseJson = pm.response. json();\r",
                      "\r",
                      "pm.test (\"Response body contains the correct goal title\", function () {\r",
                      "\r",
                      "const expectTitle = pm.collectionVariables.get(\"random_GoalTitle\");\r",
                      "const expectDescritpion = pm.collectionVariables.get(\"random_GoalDescription\");\r",
                      "\r",
                      "pm.expect(responseJson.goal.title).to.eql(expectTitle);\r",
                      "pm.expect(responseJson.goal.description).to.eql(expectDescritpion)\r",
                      "});\r",
                      "\r",
                      "pm. test(\"Response body id and createBy fields\", function () {\r",
                      "pm.expect(responseJson.goal ._id).to.be.a(\"string\")\r",
                      "pm.expect(responseJson.goal.createdBy).to.be.a(\"string\")\r",
                      "\r",
                      "});"
                    ],
                    "type": "text/javascript",
                    "packages": {},
                    "requests": {}
                  }
                },
                {
                  "listen": "prerequest",
                  "script": {
                    "exec": [
                      "let random_GoalTitle = pm.variables.replaceIn(\"{{$randomWord}}\")\r",
                      "let random_GoalDescription = pm.variables.replaceIn(\"{{$randomWord}}\")\r",
                      "\r",
                      "console.log(random_GoalTitle)\r",
                      "console.log(random_GoalDescription)\r",
                      "\r",
                      "pm.collectionVariables.set(\"random_GoalTitle\", random_GoalTitle)\r",
                      "pm.collectionVariables.set(\"random_GoalDescription\", random_GoalDescription)   \r",
                      "\r",
                      ""
                    ],
                    "type": "text/javascript",
                    "packages": {},
                    "requests": {}
                  }
                }
              ],
              "request": {
                "auth": {
                  "type": "bearer",
                  "bearer": [
                    {
                      "key": "token",
                      "value": "{{tokenAccess}}",
                      "type": "string"
                    }
                  ]
                },
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  },
                  {
                    "key": "Authorization",
                    "value": "Bearer {{tokenAccess}}"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"title\": \"{{random_GoalTitle}}\",\n  \"description\": \"{{random_GoalDescription}}\",\n  \"priority\": \"medium\",\n  \"status\": \"completed\"\n}",
                  "options": {
                    "raw": {
                      "language": "json"
                    }
                  }
                },
                "url": {
                  "raw": "{{baseUrl}}/api/v1/goals",
                  "host": [
                    "{{baseUrl}}"
                  ],
                  "path": [
                    "api",
                    "v1",
                    "goals"
                  ]
                }
              },
              "response": []
            }
